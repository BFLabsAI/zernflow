# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Late API key and AI provider key are set per-workspace in Settings UI.
# For self-hosted, you can optionally set OMNIROUTE_API_KEY/OMNIROUTE_ENDPOINT as a fallback.

# AI Provider (OmniRoute, OpenAI-compatible) for the AI Response flow node
# OMNIROUTE_ENDPOINT=http://localhost:20128/v1
# OMNIROUTE_API_KEY=your-omniroute-key

# Cron secret (for sequence processor + job scheduler)
CRON_SECRET=your-cron-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
